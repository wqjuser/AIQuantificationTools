{
  "name": "ai-quantification-tools",
  "version": "0.1.0",
  "private": true,
  "description": "Local-first AI quantitative trading platform for research, backtesting, AI review, and execution.",
  "workspaces": [
    "apps/web"
  ],
  "scripts": {
    "dev": "npm run dev --workspace @aiqt/web",
    "build": "npm run build --workspace @aiqt/web",
    "preview": "npm run preview --workspace @aiqt/web",
    "test": "npm run test:python && npm run test --workspace @aiqt/web",
    "test:python": "python -m unittest discover -s services/quant_core/tests -t services/quant_core",
    "desktop:dev": "npm run tauri:dev --workspace @aiqt/web",
    "desktop:build": "npm run tauri:build --workspace @aiqt/web",
    "api": "python tools/run_quant_api.py",
    "docker:up": "docker compose up --build",
    "docker:down": "docker compose down",
    "docker:smoke": "python tools/docker_smoke.py",
    "docker:smoke:p0": "python tools/docker_smoke.py --p0-acceptance --p0-import-check --p0-acceptance-report data/p0-acceptance.json",
    "docker:smoke:p0:validate": "python tools/docker_smoke.py --validate-p0-acceptance-report data/p0-acceptance.json",
    "docker:smoke:p1": "python tools/docker_smoke.py --p1-acceptance --p1-acceptance-report data/p1-acceptance.json",
    "docker:smoke:p1:validate": "python tools/docker_smoke.py --validate-p1-acceptance-report data/p1-acceptance.json"
  },
  "engines": {
    "node": ">=22",
    "npm": ">=10",
    "python": ">=3.12"
  }
}
