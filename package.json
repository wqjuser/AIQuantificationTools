{
  "name": "ai-quantification-tools",
  "version": "0.1.0",
  "private": true,
  "description": "Local-first AI quantitative trading platform for research, backtesting, AI review, and execution.",
  "workspaces": [
    "apps/web"
  ],
  "scripts": {
    "dev": "npm run dev --workspace @aiqt/web",
    "build": "npm run build --workspace @aiqt/web",
    "preview": "npm run preview --workspace @aiqt/web",
    "test": "npm run test:python && npm run test --workspace @aiqt/web",
    "test:python": "node tools/run_python.mjs -m unittest discover -s services/quant_core/tests -t services/quant_core",
    "desktop:dev": "npm run tauri:dev --workspace @aiqt/web",
    "desktop:build": "npm run tauri:build --workspace @aiqt/web",
    "desktop:release": "node tools/run_python.mjs tools/record_desktop_release.py",
    "desktop:release:record": "node tools/run_python.mjs tools/record_desktop_release.py --record-only",
    "stage1:daily": "node tools/run_python.mjs tools/stage1_daily_use.py --output data/stage1-daily-use.json",
    "stage1:daily:validate": "node tools/run_python.mjs tools/stage1_daily_use.py --validate data/stage1-daily-use.json",
    "stage1:preflight": "node tools/run_python.mjs tools/stage1_bootstrap_preflight.py --output data/stage1-bootstrap-preflight.json",
    "stage1:preflight:validate": "node tools/run_python.mjs tools/stage1_bootstrap_preflight.py --validate data/stage1-bootstrap-preflight.json",
    "stage1:prepare": "node tools/run_python.mjs tools/stage1_prepare.py --mode full",
    "stage1:prepare:quick": "node tools/run_python.mjs tools/stage1_prepare.py --mode quick",
    "stage1:prepare:plan": "node tools/run_python.mjs tools/stage1_prepare.py --mode full --dry-run",
    "stage1:prepare:quick:plan": "node tools/run_python.mjs tools/stage1_prepare.py --mode quick --dry-run",
    "api": "node tools/run_python.mjs tools/run_quant_api.py",
    "docker:up": "docker compose up --build",
    "docker:down": "docker compose down",
    "docker:smoke": "node tools/run_python.mjs tools/docker_smoke.py",
    "docker:smoke:p0": "node tools/run_python.mjs tools/docker_smoke.py --p0-acceptance --p0-import-check --p0-acceptance-report data/p0-acceptance.json",
    "docker:smoke:p0:validate": "node tools/run_python.mjs tools/docker_smoke.py --validate-p0-acceptance-report data/p0-acceptance.json",
    "docker:smoke:p1": "node tools/run_python.mjs tools/docker_smoke.py --p1-acceptance --p1-acceptance-report data/p1-acceptance.json",
    "docker:smoke:p1:validate": "node tools/run_python.mjs tools/docker_smoke.py --validate-p1-acceptance-report data/p1-acceptance.json",
    "docker:smoke:stage2": "node tools/run_python.mjs tools/docker_smoke.py --stage2-strategy-experiment --stage2-strategy-experiment-report data/stage2-strategy-experiment.json",
    "docker:smoke:stage2:validate": "node tools/run_python.mjs tools/docker_smoke.py --validate-stage2-strategy-experiment-report data/stage2-strategy-experiment.json",
    "docker:smoke:stage3": "node tools/run_python.mjs tools/docker_smoke.py --stage3-ai-review --stage3-ai-review-report data/stage3-ai-review.json",
    "docker:smoke:stage3:validate": "node tools/run_python.mjs tools/docker_smoke.py --validate-stage3-ai-review-report data/stage3-ai-review.json",
    "docker:smoke:stage3:live": "node tools/run_python.mjs tools/docker_smoke.py --stage3-ai-review-live-provider openai-compatible --stage3-ai-review-live-report data/stage3-ai-review-live.json",
    "docker:smoke:stage4": "node tools/run_python.mjs tools/docker_smoke.py --stage4-portfolio-paper --stage4-portfolio-paper-report data/stage4-portfolio-paper.json",
    "docker:smoke:stage4:validate": "node tools/run_python.mjs tools/docker_smoke.py --validate-stage4-portfolio-paper-report data/stage4-portfolio-paper.json",
    "docker:smoke:stage5": "node tools/run_python.mjs tools/docker_smoke.py --stage3-ai-review --stage3-ai-review-report data/stage3-ai-review.json --stage4-portfolio-paper --stage4-portfolio-paper-report data/stage4-portfolio-paper.json --stage5-shadow --stage5-shadow-report data/stage5-shadow-execution.json --stage5-sandbox-readiness --stage5-sandbox-readiness-report data/stage5-sandbox-readiness.json --stage5-sandbox-readonly-probe --stage5-sandbox-readonly-probe-report data/stage5-sandbox-readonly-probe.json --stage5-sandbox-authorization-preflight --stage5-sandbox-authorization-preflight-report data/stage5-sandbox-authorization-preflight.json --stage5-sandbox-authorization-review --stage5-sandbox-authorization-review-report data/stage5-sandbox-authorization-review.json --stage5-exit-acceptance --stage5-exit-acceptance-report data/stage5-exit-acceptance.json",
    "docker:smoke:stage5:validate": "node tools/run_python.mjs tools/docker_smoke.py --validate-stage3-ai-review-report data/stage3-ai-review.json && node tools/run_python.mjs tools/docker_smoke.py --validate-stage4-portfolio-paper-report data/stage4-portfolio-paper.json && node tools/run_python.mjs tools/docker_smoke.py --validate-stage5-shadow-report data/stage5-shadow-execution.json && node tools/run_python.mjs tools/docker_smoke.py --validate-stage5-sandbox-readiness-report data/stage5-sandbox-readiness.json && node tools/run_python.mjs tools/docker_smoke.py --validate-stage5-sandbox-readonly-probe-report data/stage5-sandbox-readonly-probe.json && node tools/run_python.mjs tools/docker_smoke.py --validate-stage5-sandbox-authorization-preflight-report data/stage5-sandbox-authorization-preflight.json && node tools/run_python.mjs tools/docker_smoke.py --validate-stage5-sandbox-authorization-review-report data/stage5-sandbox-authorization-review.json && node tools/run_python.mjs tools/docker_smoke.py --validate-stage5-exit-acceptance-report data/stage5-exit-acceptance.json",
    "docker:smoke:stage5:readiness": "node tools/run_python.mjs tools/docker_smoke.py --stage5-sandbox-readiness --stage5-sandbox-readiness-report data/stage5-sandbox-readiness.json",
    "docker:smoke:stage5:readiness:validate": "node tools/run_python.mjs tools/docker_smoke.py --validate-stage5-sandbox-readiness-report data/stage5-sandbox-readiness.json",
    "docker:smoke:stage5:readonly": "node tools/run_python.mjs tools/docker_smoke.py --stage5-sandbox-readonly-probe --stage5-sandbox-readonly-probe-report data/stage5-sandbox-readonly-probe.json",
    "docker:smoke:stage5:readonly:validate": "node tools/run_python.mjs tools/docker_smoke.py --validate-stage5-sandbox-readonly-probe-report data/stage5-sandbox-readonly-probe.json",
    "docker:smoke:stage5:authorization-preflight": "node tools/run_python.mjs tools/docker_smoke.py --stage5-sandbox-authorization-preflight --stage5-sandbox-authorization-preflight-report data/stage5-sandbox-authorization-preflight.json",
    "docker:smoke:stage5:authorization-preflight:validate": "node tools/run_python.mjs tools/docker_smoke.py --validate-stage5-sandbox-authorization-preflight-report data/stage5-sandbox-authorization-preflight.json",
    "docker:smoke:stage5:authorization-review": "node tools/run_python.mjs tools/docker_smoke.py --stage5-sandbox-authorization-review --stage5-sandbox-authorization-preflight-report data/stage5-sandbox-authorization-preflight.json --stage5-sandbox-authorization-review-report data/stage5-sandbox-authorization-review.json",
    "docker:smoke:stage5:authorization-review:validate": "node tools/run_python.mjs tools/docker_smoke.py --validate-stage5-sandbox-authorization-review-report data/stage5-sandbox-authorization-review.json",
    "docker:smoke:stage6": "node tools/run_python.mjs tools/stage6_sandbox_acceptance.py --report data/stage6-sandbox-safety.json",
    "docker:smoke:stage6:validate": "node tools/run_python.mjs tools/stage6_sandbox_acceptance.py --validate data/stage6-sandbox-safety.json",
    "docker:smoke:stage6:real": "node tools/run_python.mjs tools/stage6_sandbox_acceptance.py --real-request data/stage6-sandbox-acceptance-request.json --report data/stage6-binance-spot-testnet.json",
    "docker:smoke:stage6:real:validate": "node tools/run_python.mjs tools/stage6_sandbox_acceptance.py --validate data/stage6-binance-spot-testnet.json",
    "docker:smoke:stage6:exit:validate": "node tools/run_python.mjs tools/stage6_sandbox_acceptance.py --validate-exit data/stage6-exit-acceptance.json",
    "docker:smoke:stage7": "node tools/run_python.mjs tools/stage7_production_readonly_acceptance.py --report data/stage7-production-readonly-safety.json",
    "docker:smoke:stage7:validate": "node tools/run_python.mjs tools/stage7_production_readonly_acceptance.py --validate data/stage7-production-readonly-safety.json",
    "docker:smoke:stage7:real": "node tools/run_python.mjs tools/stage7_production_readonly_acceptance.py --real-request data/stage7-production-readonly-acceptance-request.json --report data/stage7-production-readonly.json",
    "docker:smoke:stage7:real:validate": "node tools/run_python.mjs tools/stage7_production_readonly_acceptance.py --validate data/stage7-production-readonly.json",
    "docker:smoke:stage8": "node tools/run_python.mjs tools/stage8_production_readonly_continuity_acceptance.py --report data/stage8-production-readonly-continuity.json",
    "docker:smoke:stage8:validate": "node tools/run_python.mjs tools/stage8_production_readonly_continuity_acceptance.py --validate data/stage8-production-readonly-continuity.json",
    "docker:smoke:stage8:real": "node tools/run_python.mjs tools/stage8_production_readonly_continuity_acceptance.py --real-request data/stage7-production-readonly-acceptance-request.json --report data/stage8-production-readonly-recovery.json",
    "docker:smoke:stage8:real:validate": "node tools/run_python.mjs tools/stage8_production_readonly_continuity_acceptance.py --validate data/stage8-production-readonly-recovery.json",
    "docker:smoke:stage9": "node tools/run_python.mjs tools/stage9_production_admission_acceptance.py --report data/stage9-production-admission.json",
    "docker:smoke:stage9:validate": "node tools/run_python.mjs tools/stage9_production_admission_acceptance.py --validate data/stage9-production-admission.json",
    "docker:smoke:p2:preflight": "node tools/run_python.mjs tools/docker_smoke.py --p2-chain-preflight-report data/p2-chain-preflight.json",
    "docker:smoke:p2:paper-replay": "node tools/run_python.mjs tools/docker_smoke.py --p2-paper-replay --p2-paper-replay-report data/p2-paper-replay.json",
    "docker:smoke:p2:paper-replay:validate": "node tools/run_python.mjs tools/docker_smoke.py --validate-p2-paper-replay-report data/p2-paper-replay.json",
    "docker:smoke:p2:pre-live": "node tools/run_python.mjs tools/docker_smoke.py --p2-pre-live-acceptance --p2-pre-live-acceptance-report data/p2-pre-live-acceptance.json",
    "docker:smoke:p2:pre-live:validate": "node tools/run_python.mjs tools/docker_smoke.py --validate-p2-pre-live-acceptance-report data/p2-pre-live-acceptance.json",
    "docker:smoke:p2:chain": "node tools/run_python.mjs tools/docker_smoke.py --p2-paper-replay --p2-pre-live-acceptance --p2-readiness-acceptance --p2-paper-replay-report data/p2-paper-replay.json --p2-pre-live-acceptance-report data/p2-pre-live-acceptance.json --p2-readiness-acceptance-report data/p2-readiness-acceptance.json",
    "docker:smoke:p2": "node tools/run_python.mjs tools/docker_smoke.py --p2-readiness-acceptance --p2-readiness-acceptance-report data/p2-readiness-acceptance.json",
    "docker:smoke:p2:validate": "node tools/run_python.mjs tools/docker_smoke.py --validate-p2-readiness-acceptance-report data/p2-readiness-acceptance.json"
  },
  "engines": {
    "node": "^20.19.0 || >=22.12.0",
    "npm": ">=10",
    "python": ">=3.12"
  }
}
