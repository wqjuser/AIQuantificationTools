# 共享 Web/桌面前端使用的本地 Python API。
VITE_QUANT_API_BASE=http://127.0.0.1:8765

# Stage 3 可选 AI Provider。留空时使用本地确定性研究助手。
OPENAI_API_KEY=
OPENAI_MODEL=

# OpenAI-compatible Base URL 必须包含 Provider API 前缀（例如 https://provider.example/v1），
# 但不能包含 /chat/completions；客户端按 rstrip("/") + "/chat/completions" 拼接请求路径。
OPENAI_COMPATIBLE_BASE_URL=
OPENAI_COMPATIBLE_API_KEY=
OPENAI_COMPATIBLE_MODEL=

# Docker 容器通过宿主机访问本地 Ollama；模型留空时不会启用该 Provider。
OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_MODEL=

# Stage 7 仅供 Binance Spot 生产只读准入。必须使用独立且关闭交易、提现和划转权限的 API Key；
# 不得复用 Sandbox、通用 CCXT 或未来生产下单凭据。留空时系统确定性 fail closed。
CCXT_PRODUCTION_READONLY_API_KEY=
CCXT_PRODUCTION_READONLY_SECRET=
# 容器需要代理访问 Binance 时设置为宿主机代理，例如 http://host.docker.internal:7890。
HTTPS_PROXY=

# 未来市场数据适配器使用的可选密钥。
ALPHA_VANTAGE_API_KEY=
